	"item": [
		{
			"name": "Autenticação",
			"item": [
				{
					"name": "Autenticação inicial",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Este script verifica a resposta e salva o token no ambiente ativo.\r",
									"\r",
									"pm.test(\"Response contains access_token\", function () {\r",
									"    const responseData = pm.response.json();\r",
									"\r",
									"    // Verifica se a propriedade existe\r",
									"    pm.expect(responseData.access_token).to.exist;\r",
									"\r",
									"    const token = responseData.access_token;\r",
									"    \r",
									"    // ATENÇÃO: Verifique se este nome 'accessToken' está correto e corresponde\r",
									"    // ao nome na sua tabela de variáveis.\r",
									"    if (token) {\r",
									"        // A linha crucial: Salva o token na variável de ambiente.\r",
									"        pm.environment.set(\"accessToken\", token);\r",
									"        console.log(\"Token de Acesso salvo com sucesso!\");\r",
									"    } else {\r",
									"        // Este erro só aparecerá se o teste PASSAR mas o token for vazio/nulo\r",
									"        console.error(\"Erro: access_token encontrado, mas o valor é inválido.\");\r",
									"    }\r",
									"});"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"username\": \"{{username}}\",\r\n    \"password\": \"{{password}}\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
